{
  "id": "docsight.bnetz",
  "name": "BNetzA File Watcher Module",
  "description": "Automatic import module for BNetzA PDFs/CSVs; configure the watch directory in BNetzA File Watcher.",
  "version": "1.0.0",
  "author": "itsDNNS",
  "minAppVersion": "2026.2",
  "type": "integration",
  "contributes": {
    "collector": "collector.py:BnetzWatcherCollector",
    "routes": "routes.py",
    "settings": "templates/bnetz_settings.html",
    "static": "static/",
    "i18n": "i18n/"
  },
  "config": {
    "bnetz_enabled": true,
    "bnetz_watch_enabled": false,
    "bnetz_watch_dir": "/data/bnetz"
  },
  "menu": {
    "label_key": "docsight.bnetz.bnetz_watcher_title",
    "icon": "file-check",
    "order": 24
  }
}
